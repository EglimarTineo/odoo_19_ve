<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_l10n_ve_sumitic" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n.ve.sumitic</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="l10n_ve_control_number" 
                       invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund')"
                       required="move_type in ('out_invoice', 'out_refund') and state == 'posted'"/>
                <field name="l10n_ve_taxpayer_type" readonly="1" groups="base.group_no_one"/>
            </xpath>
        </field>
    </record>
</odoo>
