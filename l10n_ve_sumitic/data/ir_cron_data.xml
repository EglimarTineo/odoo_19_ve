<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_sync_bcv_rate" model="ir.cron">
            <field name="name">Sumitic: Sincronización Diaria Tasa BCV</field>
            <field name="model_id" ref="base.model_res_currency"/>
            <field name="state">code</field>
            <field name="code">model._update_ve_bcv_rates()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 08:00:00')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
